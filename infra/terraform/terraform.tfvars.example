kubeconfig_path         = "~/.kube/config"
kubeconfig_context      = "your-cluster-context"
gitops_repo_url         = "https://github.com/mariakoneva1/vot-project-iren-mariq.git"
gitops_target_revision  = "main"
dockerhub_username      = "your-dockerhub-user"
dockerhub_token         = "replace-with-token" # pragma: allowlist secret
notification_webhook_url = "https://hooks.example.com/devops"
grafana_admin_password  = "replace-with-strong-password" # pragma: allowlist secret
app_domain              = "sprintboard.example.com"
