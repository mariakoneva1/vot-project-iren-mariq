      "id": 4,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "increase(sprintboard_task_created_total[5m])",
          "legendFormat": "created",
          "refId": "A"
        },
        {
          "expr": "increase(sprintboard_task_promoted_total[5m])",
          "legendFormat": "promoted",
          "refId": "B"
        }
